---
import Layout from "../../layouts/Slaynews.astro";
import { getCollection } from "astro:content";
import { render } from "astro:content";
import { resolveContentImage } from "../../lib/resolveContentImage";

export async function getStaticPaths() {
  const wiki = await getCollection("wiki");
  return wiki.map((page) => ({
    params: { id: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---
<Layout>
  <article class="slaynews-article">
    <header class="article-header">
      <h1>{page.data.title}</h1>
      <p>{page.data.description}</p>
    </header>

    <div class="media-panel">
      <div class="top-section">
        <img
          src={resolveContentImage(page.data.image)}
          alt={page.data.title}
          class="article-image"
        />
        <nav class="table-of-contents">
          <h3>На странице</h3>
          <ul id="headings-list"></ul>
        </nav>
      </div>

      <div class="content-markdown">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<script>
  function extractHeadings() {
    const contentMarkdown = document.querySelector('.content-markdown');
    if (!contentMarkdown) return;

    const headingsList = document.querySelector('#headings-list');
    if (!headingsList) return;

    const headings = contentMarkdown.querySelectorAll('h2, h3, h4, h5, h6');
    
    headings.forEach((heading) => {
      if (!heading.id) {
        const text = heading.textContent;
        const id = text
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-');
        heading.id = id;
      }

      const li = document.createElement('li');
      li.className = `toc-level-${heading.tagName.toLowerCase()}`;
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;
      li.appendChild(a);
      headingsList.appendChild(li);
    });
  }

  extractHeadings();
  document.addEventListener('astro:after-swap', extractHeadings);
</script>

<style>
  .media-panel {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 2rem 0;
  }

  .top-section {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .article-image {
    max-width: 300px;
    width: 100%;
    height: auto;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .table-of-contents {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 1rem;
    flex: 1;
  }

  .table-of-contents h3 {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  .table-of-contents ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .table-of-contents li {
    margin-bottom: 0.5rem;
  }

  .table-of-contents a {
    display: block;
    text-decoration: none;
    font-size: 0.9rem;
    color: inherit;
    padding: 0.25rem 0.5rem;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .table-of-contents a:hover {
    color: var(--accent-color, #fbbf24);
    border-left-color: var(--accent-color, #fbbf24);
    padding-left: 0.75rem;
  }

  .toc-level-h2 {
    padding-left: 0;
  }

  .toc-level-h2 a {
    font-weight: 500;
  }

  .toc-level-h3 {
    padding-left: 1rem;
  }

  .toc-level-h4 {
    padding-left: 2rem;
  }

  .toc-level-h5 {
    padding-left: 3rem;
  }

  .toc-level-h6 {
    padding-left: 4rem;
  }

  .content-markdown {
    width: 100%;
  }

  @media (max-width: 768px) {
    .top-section {
      flex-direction: column;
      gap: 1.5rem;
    }

    .article-image {
      max-width: 100%;
    }

    .table-of-contents {
      padding: 0.75rem;
    }

    .table-of-contents h3 {
      font-size: 0.8rem;
    }

    .table-of-contents a {
      font-size: 0.85rem;
    }
  }
</style>