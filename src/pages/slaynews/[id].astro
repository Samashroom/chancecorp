---
import Layout from "../../layouts/Slaynews.astro";
import { getCollection } from "astro:content";
import { render } from "astro:content";
import { resolveContentImage } from "../../lib/resolveContentImage";

export async function getStaticPaths() {
  const wiki = await getCollection("wiki");
  return wiki.map((page) => ({
    params: { id: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---
<Layout>
  <h1>{page.data.title}</h1>
  <img
    src={resolveContentImage(page.data.image)}
    alt={page.data.title}
    class="content-image"
  />
  <p>{page.data.description}</p>
  <div class="content-markdown">
    <Content />
  </div>
</Layout>
<style>
    .content-image {
      max-width: 50vw;
      max-height: 50vh;
      height: auto;
      margin: 20px 0;
    }
    @media (max-width: 600px) {
      .content-image {
        max-width: 90vw;
        max-height: 30vh;
      }
    }
    :global(.content-markdown table) {
      width: fit-content;
      margin: 20px auto;
    }
    :global(.content-markdown td) {
      border: 1px solid #2b2b2b;
      padding: 10px;
    }
</style>