---
import Layout from "../layouts/Home.astro";
import Card from "../components/card.astro";
import Logo from "../assets/logo.png";
---

<Layout>
  <img src={Logo.src} alt="ChanceCorp Logo" style="height: 90vh" />

  <h1>CHANCECORP</h1>

  <p>ChanceCorp - компания-монополист во всех сферах.</p>
</Layout>

<style>
  html {
    background-color: rgb(0, 38, 255);
    color: white;
  }
  h1 {
    font-size: 8rem;
    margin-top: 2rem;
    margin-bottom: 0;
    text-align: center;
    font-weight: 900;
    font-family: "Arial Black", Arial, sans-serif;
  }
  p {
    font-family: "Franklin Gothic Medium", "Arial Narrow", Arial, sans-serif;
    font-size: 1.5rem;
    text-align: center;
    max-width: 600px;
    margin: 2rem auto;
    margin-top: 0;
  }
</style>
