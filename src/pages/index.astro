import Logo from "../assets/logo.png";
---

<Layout>
  *сайт в разработке
  <img src={Logo.src} alt="ChanceCorp Logo" class = "logo"/>

  <h1>CHANCECORP</h1>
  Локации:
  
</Layout>

<style>

  html {
    background-color: rgb(0, 38, 255);
    color: white;
  }
  .logo {
    display: block;
    margin: 0 auto;
    height: 100vh;
  }
  @media (max-width: 600px) {
    .logo {
      width: 100vw;
    }
    h1 {
      font-size: 4rem;
    }
    p {
      font-size: 1.2rem;
      max-width: 90%;
    }
  }
  h1 {
    font-size: 8rem;
    margin-top: 2rem;
    margin-bottom: 0;
    text-align: center;
    font-weight: 900;
    font-family: "Arial Black", Arial, sans-serif;
  }
  p {
    font-family: "Franklin Gothic Medium", "Arial Narrow", Arial, sans-serif;
    font-size: 1.5rem;
    text-align: center;
    max-width: 600px;
    margin: 2rem auto;
    margin-top: 0;
  }
