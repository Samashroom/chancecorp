---
import Layout from "../layouts/Home.astro";
import Card from "../components/card.astro";
import Logo from "../assets/logo.png";
---

<Layout>
  *сайт в разработке
  <img src={Logo.src} alt="ChanceCorp Logo" class = "logo"/>

  <h1>CHANCECORP</h1>
  <p>Панель доступа:</p>
  <div>
    
  <a href="/anylocation/destinations">Локации</a>
  <a href="/slaynews">Персонажи</a>
  <a href="/chanceid">Мейкер карточки</a>
  </div>
  
</Layout>

<style>

:global(html) {
    background: linear-gradient(
      to bottom,
      #af0000 0%, #af0000 16.66%,
      #af7f00 16.66%, #af7f00 33.32%,
      #afaf00 33.32%, #afaf00 49.98%,
      #00af00 49.98%, #00af00 66.64%,
      #0000af 66.64%, #0000af 83.30%,
      #4f00af 83.30%, #4f00af 100%
    );
    color: white;
    font-family: "Arial", sans-serif;
  }
  .logo {
    display: block;
    margin: 0 auto;
    height: 60vh;
  }
  h1 {
    font-size: 6rem;
    margin-top: 2rem;
    margin-bottom: 0;
    text-align: center;
    font-weight: 900;
    font-family: "Arial Black", Arial, sans-serif;
  }
  p {
    font-family: "Franklin Gothic Medium", "Arial Narrow", Arial, sans-serif;
    font-size: 1.5rem;
    text-align: center;
    max-width: 600px;
    margin: 1rem auto;
    margin-top: 0;
  }
  a{
    color: white;
    text-decoration: none;
    display: inline-block;
    margin: 0rem 0.5rem;
    border: 2px solid white;
    padding: 0.5rem 1rem;
    border-radius: 5px;
    transition: background-color 0.3s, color 0.3s;
  }
  a:hover {
    background-color: white;
    color: #000000;
  }

  @media (max-width: 600px) {
    .logo {
      width: 90vw;
      height: auto;
    }
    h1 {
      font-size: 3rem;
    }
    p {
      font-size: 1.2rem;
      max-width: 90%;
    }
  }
</style>
