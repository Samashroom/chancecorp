---
// src/pages/canvas-export.astro
---

<meta charset="UTF-8" />
<div class="editor">
    <canvas
        id="previewCanvas"
        width="800"
        height="450"
        style="border:1px solid #ccc;"></canvas>

    <!-- Скрытый canvas для экспорта в высоком разрешении -->
    <canvas id="exportCanvas" width="1920" height="1080" style="display:none;"
    ></canvas>

    <div>
        <input type="text" id="userText" placeholder="Введите текст" />
        <button id="downloadBtn">Скачать в HD (1920x1080)</button>
    </div>
</div>

<script>
    const previewCanvas = document.getElementById("previewCanvas");
    const previewCtx = previewCanvas.getContext("2d");

    const exportCanvas = document.getElementById("exportCanvas");
    const exportCtx = exportCanvas.getContext("2d");

    let userInput = {
        text: "Имя",
    };

    function drawPreview() {
        previewCtx.clearRect(0, 0, previewCanvas.width, previewCanvas.height);

        previewCtx.fillStyle = "#C0C0C0";
        previewCtx.fillRect(0, 0, previewCanvas.width, previewCanvas.height);

        previewCtx.fillStyle = "#f6e606";
        previewCtx.fillRect(0, 0, previewCanvas.width, 40);

        previewCtx.fillStyle = "#1d1dca";
        previewCtx.fillRect(0, 0, 30, previewCanvas.height);

        previewCtx.fillStyle = "#0ca4ce";
        previewCtx.fillRect(45, 55, 210, 280);

        previewCtx.fillStyle = "#0ca4ce";
        previewCtx.fillRect(270, 60, 500, 45);


        // Рисуем текст
        previewCtx.fillStyle = "#1d1dca";
        previewCtx.font = "bold 32px 'Arial Narrow'";
        previewCtx.textAlign = "baseline";
        previewCtx.fillText(
            userInput.text.toUpperCase(),
            280, 105,
        );
        previewCtx.fillStyle = "#1d1dca";
        previewCtx.font = "bold 32px Arial";
        previewCtx.textAlign = "baseline";
        previewCtx.fillText(
            userInput.text,
            300, 160,
        );
    }

    // Функция отрисовки на экспорт canvas (большой)
    function drawExport() {
        exportCtx.clearRect(0, 0, exportCanvas.width, exportCanvas.height);

        // Те же самые элементы, но с масштабированными размерами
        exportCtx.fillStyle = "#f0f0f0";
        exportCtx.fillRect(0, 0, exportCanvas.width, exportCanvas.height);

        // Масштабируем размер шрифта (1920/800 = 2.4 раза)
        const scale = exportCanvas.width / previewCanvas.width; // 1920/800 = 2.4
        exportCtx.fillStyle = userInput.color;
        exportCtx.font = `bold ${32 * scale}px Arial`;
        exportCtx.textAlign = "center";
        exportCtx.fillText(
            userInput.text,
            exportCanvas.width / 2,
            exportCanvas.height / 2,
        );
    }

    // Обновление при изменении пользовательского ввода
    function updateAndDraw() {
        drawPreview();
        drawExport(); // обновляем и скрытый canvas
    }

    // Слушатели ввода
    document.getElementById("userText").addEventListener("input", (e) => {
        userInput.text = e.target.value;
        updateAndDraw();
    });


    // Скачивание
    document.getElementById("downloadBtn").addEventListener("click", () => {
        // Просто сохраняем экспортный canvas
        const link = document.createElement("a");
        link.download = "my-image.png";
        link.href = exportCanvas.toDataURL("image/png");
        link.click();
    });

    // Начальная отрисовка
    updateAndDraw();
</script>

<style>
    .editor {
        text-align: center;
        padding: 20px;
    }

    canvas {
        margin: 20px auto;
        display: block;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

    input {
        margin: 10px;
        padding: 8px;
    }

    button {
        padding: 10px 20px;
        font-size: 16px;
        background: #4caf50;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

    button:hover {
        background: #45a049;
    }
</style>
