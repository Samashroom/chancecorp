---
// src/pages/canvas-export.astro
---

<meta charset="UTF-8" />
<!-- Use stable Cropper.js v1.5.13 -->
<link
  href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css"
  rel="stylesheet"
/>
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"
></script>
<!-- Arial Narrow web font for Android and other systems -->
<link rel="stylesheet" href="https://fonts.cdnfonts.com/css/arial-narrow" />
<!-- jsPDF for PDF export -->
<script
  src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"
></script>

<div class="editor">
  <!-- УПРАВЛЕНИЕ ФОТО -->
  <div class="photo-controls">
    <input type="file" id="photoInput" accept="image/*" />
    <div class="text-controls">
      <input type="text" id="line1Input" placeholder="Имя" />
      <input type="text" id="line2Input" placeholder="Второе имя (если есть)" />
      <input type="text" id="line3Input" placeholder="Фамилия" />
      <select id="choice1Input">
        <option value=""></option>
        <option value="М">Мужской</option>
        <option value="Ж">Женский</option>
        <option value="Х">Другой</option>
      </select>
      <select id="choice1Input">
        <option value=""></option>
        <option value="М">Мужской</option>
        <option value="Ж">Женский</option>
        <option value="Х">Другой</option>
      </select>
      <input
        type="text"
        id="date1Input"
        placeholder="__.__.____"
        maxlength="10"
        inputmode="text"
        autocomplete="off"
      />
      <input
        type="text"
        id="date2Input"
        placeholder="__.__.____"
        maxlength="10"
        inputmode="text"
        autocomplete="off"
      />
      <p>
      Место регистрации
      <select id="three1Input">
        <option value=""></option>
        <option value="Полис">Полис</option>
        <option value="Сити">Сити</option>
      </select>
      <p>
      Место выдачи
      <select id="three2Input">
        <option value=""></option>
        <option value="Полис">Полис</option>
        <option value="Сити">Сити</option>
      </select>
      </p>
    </div>
    <div id="cropperContainer" class="cropper-container" style="display: none;">
      <img id="cropperImage" src="" />
      <div class="cropper-buttons">
        <button id="applyCropBtn">✓ Применить</button>
        <button id="cancelCropBtn">✕ Отмена</button>
      </div>
    </div>
  </div>

  <!-- CANVAS КАРТОЧКА -->
  <canvas id="cardCanvas"></canvas>

  <!-- КНОПКИ СКАЧИВАНИЯ -->
  <div class="download-controls">
    <button id="downloadPngBtn">📥 Скачать PNG</button>
    <button id="downloadJpgBtn">📥 Скачать JPG</button>
    <button id="downloadPdfBtn">📥 Скачать PDF</button>
  </div>
</div>

<script>
  console.log("ChanceID page script loaded");
  console.log("Cropper global:", typeof Cropper);

  const canvas = document.getElementById("cardCanvas");
  const ctx = canvas.getContext("2d");
  const photoInput = document.getElementById("photoInput");
  const cropperContainer = document.getElementById("cropperContainer");
  const cropperImage = document.getElementById("cropperImage");
  const applyCropBtn = document.getElementById("applyCropBtn");
  const cancelCropBtn = document.getElementById("cancelCropBtn");
  const downloadPngBtn = document.getElementById("downloadPngBtn");
  const downloadJpgBtn = document.getElementById("downloadJpgBtn");
  const downloadPdfBtn = document.getElementById("downloadPdfBtn");
  const line1Input = document.getElementById("line1Input");
  const line2Input = document.getElementById("line2Input");
  const line3Input = document.getElementById("line3Input");
  const choice1Input = document.getElementById("choice1Input");
  const date1Input = document.getElementById("date1Input");
  const date2Input = document.getElementById("date2Input");
  const three1Input = document.getElementById("three1Input");
  const three2Input = document.getElementById("three2Input");

  // ===== ПЕРЕМЕННАЯ ДЛЯ ХРАНЕНИЯ ФОТО =====
  let userPhoto = null;
  let cropper = null;

  // ===== ВЫСОКОЕ РАЗРЕШЕНИЕ =====
  const scale = 1;

  canvas.width = 2400 * scale;
  canvas.height = 1280 * scale;

  ctx.scale(scale, scale);

  // ===== ФУНКЦИЯ ОТРИСОВКИ КАРТОЧКИ =====
  function drawCard() {
    // ===== ФОН =====
    ctx.fillStyle = "#c0c0c0";
    ctx.fillRect(0, 0, 2400, 1280);

    // ===== СИНЯЯ ПОЛОСА СЛЕВА =====
    ctx.fillStyle = "#1d1dca";
    ctx.fillRect(0, 0, 120, 1280);

    // ===== ЖЁЛТАЯ ПОЛОСА СВЕРХУ =====
    ctx.fillStyle = "#f3e600";
    ctx.fillRect(120, 0, 2280, 90);

    // ===== ЛОГО =====
    ctx.fillStyle = "#2442c7";
    ctx.font = "bold 68px 'Arial Narrow', Arial, sans-serif";
    ctx.fillText("CHANCE id", 1980, 68);

    // ===== ФОТО БЛОК =====
    ctx.fillStyle = "#efefef";
    ctx.strokeStyle = "#2c7a88";
    ctx.lineWidth = 8;

    ctx.fillRect(60, 120, 750, 1000);
    ctx.strokeRect(60, 120, 750, 1000);

    // ===== ВСТАВКА ПОЛЬЗОВАТЕЛЬСКОГО ФОТО =====
    if (userPhoto) {
      ctx.drawImage(userPhoto, 60, 120, 750, 1000);
    }

    // ===== ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ =====
    function block(x, y, w, h, color, text, tx, ty, size = 48) {
      ctx.fillStyle = color;
      ctx.fillRect(x, y, w, h);

      ctx.fillStyle = "#8fb6c0";
      ctx.font = `bold ${size}px Arial`;
      ctx.fillText(text, tx, ty);
    }

    // ===== БЕЛЫЕ БЛОКИ =====
    block(840, 120, 1520, 150, "#ececec", "имя", 850, 160);
    block(840, 280, 1520, 150, "#ececec", "второе имя", 850, 320);
    block(840, 440, 1520, 150, "#ececec", "фамилия", 850, 480);

    // ===== СЕРЫЙ БЛОК =====
    ctx.fillStyle = "#7d8da1";
    ctx.fillRect(840, 610, 1520, 220);

    ctx.fillStyle = "#9ec1c9";
    ctx.font = "bold 48px 'Arial Narrow', Arial, sans-serif";
    ctx.fillText("гендерный маркер", 860, 660);
    ctx.fillText("дата регистрации", 1380, 660);
    ctx.fillText("дата выдачи", 1900, 660);

    // ===== НИЖНИЙ БЛОК =====
    ctx.fillStyle = "#d9eaf1";
    ctx.fillRect(840, 840, 1520, 400);

    ctx.fillStyle = "#6f8a96";
    ctx.font = "bold 56px 'Arial Narrow', Arial, sans-serif";
    ctx.fillText("место регистрации", 960, 900);
    ctx.fillText("место учёта", 1740, 900);

    // ===== НОМЕР СЧЁТА =====
    ctx.fillStyle = "#ececec";
    ctx.font = "bold 44px 'Arial Narrow', Arial, sans-serif";
    ctx.fillText("номер", 130, 1200);
    ctx.fillText("счета:", 130, 1240);

    // ===== ЗАПОЛНЕНИЕ АЙДИ =====
    ctx.fillStyle = "#14586b";
    ctx.font = "bold 80px 'Arial Narrow'";
    const v1 = line1Input && line1Input.value ? line1Input.value : "";
    const v2 = line2Input && line2Input.value ? line2Input.value : "";
    const v3 = line3Input && line3Input.value ? line3Input.value : "";
    const c1 = choice1Input && choice1Input.value ? choice1Input.value : "";
    const d1raw = date1Input && date1Input.value ? date1Input.value : "";
    const d2raw = date2Input && date2Input.value ? date2Input.value : "";
    const d1 = formatDateForCanvas(d1raw);
    const d2 = formatDateForCanvas(d2raw);
    const t1 = three1Input && three1Input.value ? three1Input.value : "";
    const t2 = three2Input && three2Input.value ? three2Input.value : "";

    ctx.fillText(v1, 860, 240);
    ctx.fillText(v2, 860, 400);
    ctx.fillText(v3, 860, 560);
    ctx.fillText(c1, 1000, 760);
    ctx.fillText(d1, 1355, 760);
    ctx.fillText(d2, 1850, 760);
    ctx.fillText(t1, 900, 1000);
    ctx.fillText(t2, 1600, 1000);
  }

  // ===== СОБЫТИЕ ЗАГРУЗКИ ФАЙЛА =====
  photoInput.addEventListener("change", function (e) {
    const file = e.target.files[0];
    if (!file) return;

    // Проверка формата файла
    if (!file.type.startsWith("image/")) {
      alert("Пожалуйста, загрузите изображение!");
      return;
    }

    const reader = new FileReader();
    reader.onload = function (event) {
      cropperImage.src = event.target.result;

      // ВАЖНО: Дождаться загрузки изображения перед инициализацией Cropper
      cropperImage.onload = function () {
        cropperContainer.style.display = "block";

        // Инициализация Cropper
        if (cropper) {
          cropper.destroy();
        }

        cropper = new Cropper(cropperImage, {
          aspectRatio: 0.75, // Пропорции 3:4
          viewMode: 1,
          autoCropArea: 1,
          responsive: true,
          restore: true,
          guides: true,
          center: true,
          highlight: true,
          cropBoxMovable: true,
          cropBoxResizable: true,
          toggleDragModeOnDblclick: true,
          background: true,
        });
      };
    };
    reader.readAsDataURL(file);
  });

  // ===== ПРИМЕНИТЬ ОБРЕЗАННОЕ ФОТО =====
  applyCropBtn.addEventListener("click", function () {
    if (!cropper) return;

    const canvas2 = cropper.getCroppedCanvas({
      maxWidth: 750,
      maxHeight: 1000,
      imageSmoothingEnabled: true,
      imageSmoothingQuality: "high",
    });

    // Преобразуем canvas в изображение
    userPhoto = new Image();

    // ВАЖНО: Дождаться загрузки изображения перед отрисовкой
    userPhoto.onload = function () {
      drawCard();

      // Скрываем Cropper контейнер
      cropperContainer.style.display = "none";
      cropper.destroy();
      cropper = null;
    };

    userPhoto.src = canvas2.toDataURL();
  });

  // ===== ОТМЕНА =====
  cancelCropBtn.addEventListener("click", function () {
    if (cropper) {
      cropper.destroy();
      cropper = null;
    }
    cropperContainer.style.display = "none";
    photoInput.value = "";
  });

  // Re-draw when inputs change; use change event for select
  [
    line1Input,
    line2Input,
    line3Input,
    date1Input,
    date2Input,
    three1Input,
    three2Input,
  ].forEach((el) => {
    if (el) el.addEventListener("input", drawCard);
  });
  if (choice1Input) choice1Input.addEventListener("change", drawCard);

  // ===== МАСКА ДЛЯ ПОЛЕЙ ДАТ (raw без точек) =====
  function formatDateForCanvas(raw) {
    const r = (raw || "").replace(/\./g, "");
    if (!r) return "";
    const a = r.slice(0, 2);
    const b = r.slice(2, 4);
    const c = r.slice(4, 8);
    let out = a;
    if (b) out += "." + b;
    if (c) out += "." + c;
    return out;
  }

  function formatDateDisplay(raw) {
    const r = raw.replace(/\./g, "");
    const a = r.slice(0, 2);
    const b = r.slice(2, 4);
    const c = r.slice(4, 8);
    let out = a;
    if (b) out += "." + b;
    if (c) out += "." + c;
    return out;
  }

  function getRawDateValue(value) {
    return (value || "").replace(/\./g, "");
  }

  function displayCursorPos(rawPos) {
    if (rawPos <= 2) return rawPos;
    if (rawPos <= 4) return rawPos + 1;
    return rawPos + 2;
  }

  function attachDateMask(el) {
    if (!el) return;

    el.addEventListener("input", function () {
      const rawBefore = getRawDateValue(
        el.value.slice(0, el.selectionStart || 0),
      );
      const filtered = getRawDateValue(el.value)
        .replace(/[^0-9A-Za-z]/g, "")
        .toUpperCase()
        .slice(0, 8);
      const formatted = formatDateDisplay(filtered);
      el.value = formatted;
      const cursorPosition = displayCursorPos(
        Math.min(rawBefore.length, filtered.length),
      );
      el.setSelectionRange(cursorPosition, cursorPosition);
      drawCard();
    });

    el.addEventListener("keydown", function (e) {
      const nav = [
        "Backspace",
        "Delete",
        "ArrowLeft",
        "ArrowRight",
        "Tab",
        "Home",
        "End",
      ];
      if (e.ctrlKey || e.metaKey || nav.includes(e.key)) return;
      if (e.key.length === 1 && !/^[0-9A-Za-z]$/.test(e.key)) {
        e.preventDefault();
      }
      const raw = getRawDateValue(el.value).replace(/[^0-9A-Za-z]/g, "");
      if (raw.length >= 8 && e.key.length === 1 && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
      }
    });

    el.addEventListener("paste", function (e) {
      e.preventDefault();
      const paste =
        (e.clipboardData || window.clipboardData).getData("text") || "";
      const raw = getRawDateValue(el.value) + paste;
      const combined = raw
        .replace(/[^0-9A-Za-z]/g, "")
        .toUpperCase()
        .slice(0, 8);
      el.value = formatDateDisplay(combined);
      drawCard();
    });
  }

  attachDateMask(date1Input);
  attachDateMask(date2Input);

  // ===== ФУНКЦИИ СКАЧИВАНИЯ =====
  function downloadImage(format) {
    const link = document.createElement("a");
    const timestamp = new Date().toISOString().slice(0, 10);
    const name = `CHANCE_id_${timestamp}`;

    if (format === "png") {
      link.href = canvas.toDataURL("image/png");
      link.download = name + ".png";
    } else if (format === "jpg") {
      link.href = canvas.toDataURL("image/jpeg", 0.95);
      link.download = name + ".jpg";
    }

    link.click();
  }

  function downloadPDF() {
    const timestamp = new Date().toISOString().slice(0, 10);
    const filename = `CHANCE_id_${timestamp}.pdf`;

    // Get canvas as image data
    const imgData = canvas.toDataURL("image/png");

    // Create PDF with landscape orientation
    const { jsPDF } = window;
    const pdf = new jsPDF({
      orientation: "landscape",
      unit: "px",
      format: [2400, 1280],
    });

    // Add image to PDF
    pdf.addImage(imgData, "PNG", 0, 0, 2400, 1280);

    // Save PDF
    pdf.save(filename);
  }

  // ===== ОБРАБОТЧИКИ КНОПОК СКАЧИВАНИЯ =====
  if (downloadPngBtn)
    downloadPngBtn.addEventListener("click", () => downloadImage("png"));
  if (downloadJpgBtn)
    downloadJpgBtn.addEventListener("click", () => downloadImage("jpg"));
  if (downloadPdfBtn) downloadPdfBtn.addEventListener("click", downloadPDF);

  // ===== ПЕРВОНАЧАЛЬНАЯ ОТРИСОВКА =====
  drawCard();
</script>

<style>
  .editor {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 20px;
  }

  canvas {
    display: block;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    border: 1px solid #ddd;
  }

  /* ===== УПРАВЛЕНИЕ ФОТО ===== */
  .photo-controls {
    display: flex;
    flex-direction: column;
    gap: 15px;
    background: #f5f5f5;
    padding: 20px;
    border-radius: 8px;
  }

  .text-controls {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 12px;
    align-items: center;
  }

  .text-controls input,
  .text-controls select {
    padding: 8px 10px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 14px;
    font-family: "Arial Narrow", Arial, sans-serif;
  }

  #photoInput {
    padding: 10px;
    border: 2px solid #1d1dca;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    font-family: "Arial Narrow", Arial, sans-serif;
  }

  #photoInput::file-selector-button {
    background: #2442c7;
    color: white;
    padding: 8px 16px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
    margin-right: 10px;
  }

  #photoInput::file-selector-button:hover {
    background: #1d1dca;
  }

  /* ===== CROPPER КОНТЕЙНЕР ===== */
  .cropper-container {
    background: white;
    border: 2px solid #2c7a88;
    border-radius: 8px;
    padding: 15px;
    max-width: 600px;
  }

  #cropperImage {
    max-width: 100%;
    max-height: 400px;
  }

  .cropper-buttons {
    display: flex;
    gap: 10px;
    margin-top: 15px;
    justify-content: center;
  }

  button {
    padding: 10px 20px;
    font-size: 16px;
    background: #4caf50;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-weight: bold;
    transition: background 0.3s;
  }

  button:hover {
    background: #45a049;
  }

  #cancelCropBtn {
    background: #f44336;
  }

  #cancelCropBtn:hover {
    background: #da190b;
  }

  input,
  select {
    margin: 10px;
    padding: 8px;
  }

  /* ===== DOWNLOAD CONTROLS ===== */
  .download-controls {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .download-controls button {
    background: #2196f3;
    padding: 12px 20px;
    font-size: 16px;
    border-radius: 6px;
    font-family: "Arial Narrow", Arial, sans-serif;
  }

  .download-controls button:hover {
    background: #0b7dda;
  }

  @media (max-width: 900px) {
    .editor {
      padding: 16px;
    }

    canvas {
      width: 100%;
      height: auto;
      max-width: 100%;
    }

    .photo-controls {
      padding: 16px;
    }

    .text-controls {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .text-controls input,
    .text-controls select {
      width: 100%;
    }

    .download-controls {
      flex-direction: column;
      align-items: stretch;
    }

    .download-controls button {
      width: 100%;
      padding: 14px;
    }
  }

  @media (max-width: 640px) {
    .editor {
      gap: 16px;
      padding: 12px;
    }

    .photo-controls {
      gap: 12px;
    }

    .text-controls {
      gap: 8px;
    }

    .download-controls {
      gap: 8px;
    }

    button {
      font-size: 14px;
      padding: 12px 16px;
    }
  }
</style>
