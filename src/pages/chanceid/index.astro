// src/pages/canvas-export.astro
---

<meta charset="UTF-8" />
<div class="editor">
  <canvas id="cardCanvas"></canvas>
</div>

<script>
  const canvas = document.getElementById("cardCanvas");
  const ctx = canvas.getContext("2d");

  // ===== ВЫСОКОЕ РАЗРЕШЕНИЕ =====
  const scale = 3;

  canvas.width = 1200 * scale;
  canvas.height = 700 * scale;

  ctx.scale(scale, scale);

  // ===== ФОН =====
  ctx.fillStyle = "#c0c0c0";
  ctx.fillRect(0, 0, 1200, 700);

  // ===== СИНЯЯ ПОЛОСА СЛЕВА =====
  ctx.fillStyle = "#1d1dca";
  ctx.fillRect(0, 0, 60, 700);

  // ===== ЖЁЛТАЯ ПОЛОСА СВЕРХУ =====
  ctx.fillStyle = "#f3e600";
  ctx.fillRect(60, 0, 1140, 45);

  // ===== ЛОГО =====
  ctx.fillStyle = "#2442c7";
  ctx.font = "bold 34px Arial";
  ctx.fillText("CHANCE id", 990, 34);

  // ===== ФОТО БЛОК =====
  ctx.fillStyle = "#efefef";
  ctx.strokeStyle = "#2c7a88";
  ctx.lineWidth = 4;

  ctx.fillRect(30, 80, 370, 530);
  ctx.strokeRect(30, 80, 370, 530);

  // ===== ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ =====
  function block(x, y, w, h, color, text, tx, ty, size = 24) {
    ctx.fillStyle = color;
    ctx.fillRect(x, y, w, h);

    ctx.fillStyle = "#8fb6c0";
    ctx.font = `bold ${size}px Arial`;
    ctx.fillText(text, tx, ty);
  }

  // ===== БЕЛЫЕ БЛОКИ =====
  block(420, 85, 750, 100, "#ececec", "имя", 430, 120);
  block(420, 190, 750, 100, "#ececec", "второе имя", 430, 225);
  block(420, 295, 750, 100, "#ececec", "фамилия", 430, 330);

  // ===== СЕРЫЙ БЛОК =====
  ctx.fillStyle = "#7d8da1";
  ctx.fillRect(420, 410, 750, 190);

  ctx.fillStyle = "#9ec1c9";
  ctx.font = "bold 24px Arial";
  ctx.fillText("гендерный маркер", 435, 445);
  ctx.fillText("место регистрации", 810, 445);
  ctx.fillText("дата регистрации", 435, 515);

  // ===== НИЖНИЙ БЛОК =====
  ctx.fillStyle = "#c9d9df";
  ctx.fillRect(420, 610, 750, 140);

  ctx.fillStyle = "#6f8a96";
  ctx.font = "bold 28px Arial";
  ctx.fillText("дата выдачи", 485, 645);
  ctx.fillText("карта выдана", 860, 640);

  // ===== НОМЕР СЧЁТА =====
  ctx.fillStyle = "#ececec";
  ctx.font = "bold 22px Arial";
  ctx.fillText("номер", 65, 640);
  ctx.fillText("счета:", 65, 665);
</script>

<style>

  canvas {
    display: block;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
  }

  input {
    margin: 10px;
    padding: 8px;
  }

  button {
    padding: 10px 20px;
    font-size: 16px;
    background: #4caf50;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
  }

  button:hover {
    background: #45a049;
  }
</style>
