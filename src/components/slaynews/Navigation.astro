---
const baseUrl = import.meta.env.BASE_URL;
---
<nav class="slaynav">
  <div class="slaynav-inner">
    <a href="/slaynews" class="logo">Slaynews</a>
    <button class="burger" aria-label="Toggle menu" type="button">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-links">
      <li><a href="/slaynews">Главная</a></li>
      <li><a href="/slaynews">Персонажи</a></li>
      <li><a href="/slaynews">Хайп</a></li>
      <li><a href="/slaynews">Архив</a></li>
    </ul>
  </div>
</nav>

<script>
  const burger = document.querySelector(".burger");
  const navLinks = document.querySelector(".nav-links");

  if (burger && navLinks) {
    burger.addEventListener("click", () => {
      burger.classList.toggle("active");
      navLinks.classList.toggle("active");
    });

    document.querySelectorAll(".nav-links a").forEach((link) => {
      link.addEventListener("click", () => {
        burger.classList.remove("active");
        navLinks.classList.remove("active");
      });
    });
  }
</script>

<style>
  .slaynav {
    width: 100%;
    margin-top: 1rem;
    background: transparent;
    border-bottom: 3px solid #7f1d1d;
    top: 0;
    z-index: 999;
  }

  .slaynav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: "Lucida Console", "Courier New", monospace;
  }

  .logo {
    color: #5e0f0f;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: "Lucida Console", "Courier New", monospace;
  }

  .nav-links li {
    position: relative;
  }

  .nav-links a {
    color: #5e0f0f;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: #c1272d;
    background: transparent;
    transform: none;
  }

  .nav-links a::before {
    content: none;
  }

  .nav-links a:hover::before {
    width: 65%;
  }

  .burger {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
  }

  .burger span {
    display: block;
    width: 26px;
    height: 3px;
    background: #ffe6e6;
    margin: 5px 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .burger.active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .burger.active span:nth-child(2) {
    opacity: 0;
  }

  .burger.active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  @media (max-width: 900px) {
    .slaynav-inner {
      justify-content: space-between;
      padding: 1rem;
    }

    .nav-links {
      position: fixed;
      top: 68px;
      right: -100%;
      width: min(260px, 90vw);
      flex-direction: column;
      align-items: stretch;
      background: rgba(75, 5, 5, 0.96);
      padding: 1.5rem;
      gap: 0.75rem;
      box-shadow: -10px 10px 30px rgba(0, 0, 0, 0.4);
      transition: right 0.25s ease;
      border-radius: 1rem 0 0 1rem;
      z-index: 998;
      height: calc(100vh - 68px);
      overflow-y: auto;
    }

    .nav-links.active {
      right: 0;
    }

    .nav-links a {
      padding: 0.9rem 1rem;
      text-align: center;
      width: 100%;
      border-radius: 0.85rem;
    }

    .burger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  }

  @media (max-width: 560px) {
    .slaynav-inner {
      padding: 0.75rem 1rem;
    }

    .logo {
      font-size: 1.25rem;
    }
  }
</style>
